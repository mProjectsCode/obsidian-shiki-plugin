{
	"name": "shiki-highlighter",
	"version": "0.7.1",
	"description": "Highlight code blocks with Shiki.",
	"main": "main.js",
	"scripts": {
		"dev": "bun run automation/build/esbuild.dev.config.ts",
		"build": "bun run tsc && bun run automation/build/esbuild.config.ts",
		"tsc": "tsc -noEmit -skipLibCheck",
		"test": "bun test",
		"test:log": "LOG_TESTS=true bun test",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint --max-warnings=0 src/**",
		"lint:fix": "eslint --max-warnings=0 --fix src/**",
		"check": "bun run format:check && bun run tsc && bun run lint && bun run test",
		"check:fix": "bun run format && bun run tsc && bun run lint:fix && bun run test",
		"release": "bun run automation/release.ts",
		"stats": "bun run automation/stats.ts"
	},
	"keywords": [],
	"author": "Moritz Jung",
	"license": "MIT",
	"devDependencies": {
		"@codemirror/language": "^6.12.1",
		"@codemirror/state": "^6.5.4",
		"@codemirror/view": "^6.39.15",
		"@eslint/js": "^9.39.2",
		"@expressive-code/core": "^0.41.6",
		"@expressive-code/plugin-collapsible-sections": "^0.41.6",
		"@expressive-code/plugin-frames": "^0.41.6",
		"@expressive-code/plugin-line-numbers": "^0.41.6",
		"@expressive-code/plugin-shiki": "^0.41.6",
		"@expressive-code/plugin-text-markers": "^0.41.6",
		"@happy-dom/global-registrator": "^20.6.3",
		"@lemons_dev/parsinom": "^0.1.0",
		"@lezer/common": "^1.5.1",
		"@tsconfig/svelte": "^5.0.8",
		"@types/bun": "^1.3.9",
		"builtin-modules": "^5.0.0",
		"esbuild": "^0.27.3",
		"esbuild-plugin-copy-watch": "^2.3.1",
		"eslint": "^9.39.2",
		"eslint-plugin-no-relative-import-paths": "^1.6.1",
		"eslint-plugin-only-warn": "^1.1.0",
		"itertools-ts": "^2.5.0",
		"obsidian": "latest",
		"prettier": "^3.8.1",
		"shiki": "^3.22.0",
		"string-argv": "^0.3.2",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.0"
	}
}
